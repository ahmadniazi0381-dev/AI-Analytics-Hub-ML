FLASK_ENV=development
FLASK_APP=wsgi.py
SECRET_KEY=replace-with-a-long-random-secret-key-at-least-32-characters
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret-key-at-least-32-characters
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/ai_analytics_hub
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
RATELIMIT_STORAGE_URI=redis://redis:6379/3
UPLOAD_DIR=data/uploads
REPORT_DIR=data/reports
LOG_DIR=logs
MODEL_CACHE_DIR=data/model_cache
MAX_CONTENT_LENGTH_MB=250
ASYNC_TASKS_ENABLED=true
DEFAULT_ADMIN_EMAIL=admin@gmail.com
DEFAULT_ADMIN_PASSWORD=admin@123
CHAT_PROVIDER=openrouter
CHAT_MAX_HISTORY_MESSAGES=16
CHAT_REQUEST_TIMEOUT_SECONDS=45
CHAT_SYSTEM_PROMPT=You are the AI Analytics Hub assistant. Help users analyze data, understand AI outputs, and make practical product decisions in a professional tone.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=http://localhost:5000
OPENROUTER_SITE_NAME=AI Analytics Hub
